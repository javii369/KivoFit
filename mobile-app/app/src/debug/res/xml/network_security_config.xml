<?xml version="1.0" encoding="utf-8"?>
<!--
  Solo variantes debug: permite HTTP (cleartext) hacia la IP de tu PC en LAN.
  En release se usa el network_security_config de main (más restrictivo).
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
